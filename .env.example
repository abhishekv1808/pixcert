# Lead capture destinations for /api/lead
# Configure at least one. If none are set, leads are only logged
# server-side (dev) and the form returns an error in production.
# Copy this file to .env.local and fill in real values.

# --- Option A: forward each lead to a webhook (n8n / Zapier / Make) ---
# LEAD_WEBHOOK_URL="https://your-n8n-instance/webhook/itbizone-leads"

# --- Option B: store leads in Supabase (table: public.leads) ---
# The `leads` table uses insert-only RLS, so the anon key is safe to use.
# SUPABASE_KEY may be the anon key (recommended) or a service-role key.
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_KEY="your-anon-or-service-role-key"

# Bizo AI concierge (/api/chat). Without this, the chat shows a friendly
# fallback pointing visitors to WhatsApp / the contact form.
# ANTHROPIC_API_KEY="sk-ant-..."

# Analytics (optional — set either, both, or neither). Conversion events
# (lead_submit, chat_open, chat_message_sent, cta_click, page_view) fire
# through whichever provider is loaded.
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"              # Google Analytics 4
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="itbizone.com"  # Plausible (privacy-first)

